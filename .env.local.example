# Copie este arquivo para `.env.local` e substitua os valores abaixo.

SUPABASE_PROJECT_REF=[PROJECT-REF]
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[SUPABASE-PUBLISHABLE-KEY]
SUPABASE_DB_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=[SUPABASE-SERVICE-ROLE-KEY]
APP_SESSION_SECRET=[SESSION-SECRET-FORTE]
SISCORE_CREDENTIALS_KEY=[CHAVE-FORTE-PARA-CIFRAR-CREDENCIAIS]

SISCORE_BASE_URL=http://siscore.inovacapixaba.es.gov.br
# Opcional para o script `npm run siscore:import`.
# Em producao, o login do app grava a senha cifrada no Supabase
# e a sincronizacao usa a credencial do usuario da sessao atual.
SISCORE_USUARIO=[SISCORE-USUARIO]
SISCORE_SENHA=[SISCORE-SENHA]
SISCORE_CREDENTIALS_USUARIO=[SISCORE-USUARIO-PARA-LER-A-CREDENCIAL-CIFRADA]
SISCORE_EXPORTACAO_URL=/export_home?unidade=iNOVA&especie=MATERIAL%20HOSPITALAR&faixa=&campo=&pesquisa=&sn_padronizado=&sn_padronizado=&sn_movimentacao=&sn_bloqueio_de_compra=&sn_cmm=None&sn_pscotropico=
SISCORE_EXPORTACAO_URL_FARMACOLOGICO=/export_home?unidade=iNOVA&especie=MATERIAL%20FARMACOL%C3%93GICO&faixa=&campo=&pesquisa=&sn_padronizado=&sn_padronizado=&sn_movimentacao=&sn_bloqueio_de_compra=&sn_cmm=None&sn_pscotropico=
SISCORE_EXPORTACAO_URL_NOTAS_FISCAIS=/export_notasfiscais?unidade=
# Opcional: all | estoque | material_hospitalar | material_farmacologico | notas_fiscais
# SISCORE_SYNC_SCOPE=all
# Opcional: legacy | rpc
# SISCORE_ESTOQUE_MODO=rpc
# SISCORE_NOTAS_FISCAIS_MODO=rpc
GITHUB_ACTIONS_REPOSITORY=HugorMW/AlmoxHMSA
GITHUB_ACTIONS_SYNC_WORKFLOW=siscore-sync.yml
GITHUB_ACTIONS_SYNC_WORKFLOW_ESTOQUE=siscore-sync.yml
GITHUB_ACTIONS_SYNC_WORKFLOW_NOTAS=siscore-sync-notas.yml
GITHUB_ACTIONS_SYNC_REF=master
GITHUB_ACTIONS_TRIGGER_TOKEN=[GITHUB-TOKEN-COM-PERMISSAO-DE-WORKFLOW]
